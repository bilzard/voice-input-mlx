# --- Hotkey Configuration ---
# Key to trigger/stop recording (e.g., f13, ctrl, cmd)
VOICE_INPUT_HOTKEY=f13

# --- Server Configuration ---
# WebSocket URL for the whisper-server
VOICE_INPUT_SERVER=ws://localhost:8991

# --- Whisper Model ---
# Specify HuggingFace model path (optimized for MLX)
# Recommended: mlx-community/whisper-large-v3-turbo (High Accuracy)
# Faster: mlx-community/whisper-small-mlx (High Speed)
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# --- Transcription Settings ---
# Default language code ('en', 'ja', etc.)
DEFAULT_LANGUAGE=en
